# ── Base de datos ─────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Autenticación JWT ──────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Generar con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria-minimo-32-chars
JWT_EXPIRES_IN=24h

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tu-proyecto.vercel.app

# ── Rate Limiting (opcional, valores por defecto en server.js) ─────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_GEODATA_MAX=1000

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   # trace | debug | info | warn | error
