# Configuración del Backend - GeoVisor Alcaldía
PORT=3001
NODE_ENV=development

# JWT Secret (cambiar en producción)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# GeoServer
GEOSERVER_URL=http://localhost:8080/geoserver
GEOSERVER_WORKSPACE=AlcaldiaGeovisor

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qgis
DB_USER=postgres
DB_PASSWORD=your-password-here
